{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minamo.local/schemas/expression-mapping.schema.json",
  "title": "Minamo Expression Mapping",
  "type": "object",
  "required": ["schema", "name", "targets"],
  "properties": {
    "schema": { "const": "minamo.expression-map.v1" },
    "name": { "type": "string", "minLength": 1 },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["out", "expr", "curve", "clamp"],
        "properties": {
          "out": { "type": "string", "minLength": 1 },
          "expr": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "array",
              "prefixItems": [
                { "type": "string", "minLength": 1 },
                { "type": "number", "minimum": -4, "maximum": 4 }
              ],
              "items": false,
              "minItems": 2,
              "maxItems": 2
            }
          },
          "curve": { "enum": ["linear", "ease", "easeIn", "easeOut"] },
          "clamp": {
            "type": "array",
            "prefixItems": [{ "type": "number" }, { "type": "number" }],
            "items": false,
            "minItems": 2,
            "maxItems": 2
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
