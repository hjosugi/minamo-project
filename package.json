{
  "name": "minamo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && vite build && node scripts/copy-pages-static.mjs",
    "lint": "node scripts/lint.mjs",
    "preview": "vite preview",
    "test": "node tests/run-tests.mjs && vitest run",
    "verify": "python3 scripts/verify_structure.py",
    "release:smoke": "node scripts/release-smoke.mjs",
    "typecheck:js": "tsc --noEmit -p tsconfig.browser-js.json",
    "inspect:glb": "node scripts/inspect-glb.mjs",
    "pack:avatar": "node scripts/kagami-pack.mjs",
    "benchmark:drum": "tsx scripts/drum-benchmark.ts"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@pixiv/three-vrm": "^3.5.4",
    "ag-psd": "^31.0.2",
    "qrcode": "1.5.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
