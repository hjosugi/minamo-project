FROM node:22-alpine AS deps
WORKDIR /app/relay-node
COPY relay-node/package.json ./
RUN npm install --omit=dev

FROM node:22-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production
COPY --from=deps /app/relay-node/node_modules ./relay-node/node_modules
COPY . .
EXPOSE 8787
CMD ["node", "relay-node/server.mjs"]
